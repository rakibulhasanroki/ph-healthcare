model MedicalReport {
  id         String   @id @default(uuid(7))
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  patientId  String
  reportLink String
  reportName String
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@map("medical_reports")
}
